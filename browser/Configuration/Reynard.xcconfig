CURRENT_VERSION = 0.4.0
CURRENT_BUILD = UNKNOWN

IPHONEOS_DEPLOYMENT_TARGET = 13.0
ARCHS = arm64
VALID_ARCHS = arm64

ENABLE_BITCODE = NO

// ── Build optimisations ────────────────────────────────────────────────────────
// Whole-module optimisation: the Swift compiler sees all source files at once,
// enabling dead-code inlining and devirtualisation across the module.
// -Osize is like -Onone + -O but biased toward binary size over raw speed;
// still measurably faster than no optimisation on a 2 GB device.
SWIFT_OPTIMIZATION_LEVEL = -Osize

// C/ObjC: optimise for size.  Equivalent to -O2 plus size-reduction passes.
// Smaller binary → faster mmap, fewer page faults, lower peak RSS.
GCC_OPTIMIZATION_LEVEL = s

// Dead-code stripping is a *linker* flag (-dead_strip) – it operates on
// object files before the final binary is written, so it is safe for
// pre-built frameworks like GeckoView.  Do NOT set STRIP_STYLE or
// STRIP_INSTALLED_PRODUCT here – those invoke `strip` as a post-build step
// which cannot strip indirect-symbol-table symbols in GeckoView.framework.
DEAD_CODE_STRIPPING = YES

// ── Gecko paths ───────────────────────────────────────────────────────────────
GECKO_DIST = $(SRCROOT)/../engine/firefox/obj-aarch64-apple-ios/dist

HEADER_SEARCH_PATHS = $(inherited) $(GECKO_DIST)/include $(GECKO_DIST)/include/GeckoView $(SRCROOT)/GeckoView
LIBRARY_SEARCH_PATHS = $(inherited) $(GECKO_DIST)/bin
FRAMEWORK_SEARCH_PATHS = $(inherited) $(BUILT_PRODUCTS_DIR)
LD_RUNPATH_SEARCH_PATHS = $(inherited) @executable_path/Frameworks @loader_path/Frameworks
SWIFT_OBJC_BRIDGING_HEADER = $(SRCROOT)/Reynard/Bridging/Reynard-Bridging-Header.h
