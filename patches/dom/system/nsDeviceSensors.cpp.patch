+
+nsDeviceSensors::SensorPermissionState
+nsDeviceSensors::GetDeviceSensorPermission(nsIDOMWindow* aWindow) {
+  nsCOMPtr<nsPIDOMWindowInner> window = do_QueryInterface(aWindow);
+  if (!window) {
+    return SensorPermissionState::Denied;
+  }
+
+  nsCOMPtr<Document> doc = window->GetExtantDoc();
+  if (!doc) {
+    return SensorPermissionState::Denied;
+  }
+
+  PermissionDelegateHandler* handler = doc->GetPermissionDelegateHandler();
+  if (!handler) {
+    return SensorPermissionState::Denied;
+  }
+
+  uint32_t permission = nsIPermissionManager::UNKNOWN_ACTION;
+  nsresult rv =
+      handler->GetPermission(kDeviceSensorsPermission, &permission, false);
+  if (NS_FAILED(rv)) {
+    return SensorPermissionState::Denied;
+  }
+
+  if (permission == nsIPermissionManager::ALLOW_ACTION) {
+    return SensorPermissionState::Granted;
+  }
+
+  if (permission == nsIPermissionManager::DENY_ACTION) {
+    return SensorPermissionState::Denied;
+  }
+
+  return SensorPermissionState::Prompt;
+}
+
+void nsDeviceSensors::QueueSensorPermissionRequest(uint32_t aType,
+                                                   nsIDOMWindow* aWindow) {
+  for (PendingSensorPermission& pending : mPendingSensorPermissions) {
+    if (pending.mWindow == aWindow) {
+      if (!pending.mTypes.Contains(aType)) {
+        pending.mTypes.AppendElement(aType);
+      }
+      return;
+    }
+  }
+
+  nsCOMPtr<nsPIDOMWindowInner> window = do_QueryInterface(aWindow);
+  if (!window || !window->IsCurrentInnerWindow() || !window->GetExtantDoc()) {
+    return;
+  }
+
+  PendingSensorPermission* pending = mPendingSensorPermissions.AppendElement();
+  pending->mWindow = aWindow;
+  pending->mTypes.AppendElement(aType);
+
+  RefPtr<DeviceSensorPermissionRequest> request =
+      new DeviceSensorPermissionRequest(this, window);
+  if (NS_FAILED(request->Start())) {
+    ResolveSensorPermissionRequest(aWindow, false);
+  }
+}
+
+void nsDeviceSensors::ResolveSensorPermissionRequest(nsIDOMWindow* aWindow,
+                                                     bool aAllow) {
+  nsTArray<uint32_t> types;
+  for (uint32_t i = 0; i < mPendingSensorPermissions.Length(); i++) {
+    if (mPendingSensorPermissions[i].mWindow == aWindow) {
+      types = std::move(mPendingSensorPermissions[i].mTypes);
+      mPendingSensorPermissions.RemoveElementAt(i);
+      break;
+    }
+  }
+
+  if (!aAllow || types.IsEmpty()) {
+    return;
+  }
+
+  nsCOMPtr<nsPIDOMWindowInner> window = do_QueryInterface(aWindow);
+  if (!window || !window->IsCurrentInnerWindow()) {
+    return;
+  }
+
+  for (uint32_t type : types) {
+    AddWindowListenerInternal(type, aWindow, true);
+  }
+}
