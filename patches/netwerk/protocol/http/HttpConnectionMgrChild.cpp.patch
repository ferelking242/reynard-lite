+mozilla::ipc::IPCResult HttpConnectionMgrChild::RecvStoreServerCertHashes(
+    const HttpConnectionInfoCloneArgs& aConnInfo, const bool& aNoSpdy,
+    const bool& aNoHttp3,
+    nsTArray<mozilla::ipc::WebTransportHash>&& aServerCertHashes) {
+  RefPtr<nsHttpConnectionInfo> cinfo =
+      nsHttpConnectionInfo::DeserializeHttpConnectionInfoCloneArgs(aConnInfo);
+  nsTArray<RefPtr<nsIWebTransportHash>> nsServerCertHashes;
+  nsServerCertHashes.SetCapacity(aServerCertHashes.Length());
+  for (const auto& hash : aServerCertHashes) {
+    nsCString algorithm = hash.algorithm();
+    nsServerCertHashes.AppendElement(
+        new mozilla::net::WebTransportHash(algorithm, hash.value()));
+  }
+
+  (void)mConnMgr->StoreServerCertHashes(cinfo, aNoSpdy, aNoHttp3,
+                                        std::move(nsServerCertHashes));
+  return IPC_OK();
+}
