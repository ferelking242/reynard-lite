diff --git a/build/moz.configure/toolchain.configure b/build/moz.configure/toolchain.configure
--- a/build/moz.configure/toolchain.configure
+++ b/build/moz.configure/toolchain.configure
@@ -1795,6 +1795,12 @@
             if retcode == 1 and "Logging ld64 options" in stderr:
                 kind = "ld64"
 
+
+            elif retcode == 1 and linker == "ld64":
+                # REYNARD: Xcode 26+ ld64 no longer emits "Logging ld64 options"
+                # via LD_PRINT_OPTIONS=1. An exit code of 1 for the --version
+                # probe is conclusive evidence that ld64 is present and working.
+                kind = "ld64"
             elif retcode != 0:
                 return None
 
@@ -1851,6 +1857,15 @@
         if result is None:
             result = try_linker(None)
 
+        # REYNARD: On Darwin (macOS/iOS host), Xcode 26+ ld64 changed its debug
+        # output, breaking Firefox 152's ld64 auto-detection which relies on
+        # "Logging ld64 options" in stderr.  If all auto-detection paths failed
+        # and we are on a Darwin host, try ld64 explicitly as a last resort.
+        # try_linker("ld64") is patched above to accept the new exit-code-1
+        # probe result on Xcode 26+, so this will succeed.
+        if result is None and target.kernel == "Darwin":
+            result = try_linker("ld64")
+
         if result is None:
             die("Failed to find an adequate linker")
 
